        {
          "id": "ch1-lv3",
          "number": 3,
          "title": "第三关",
          "topic": "职业と国籍",
          "grammar": ["〜は〜人です", "〜は〜の〜です"],
          "icon": "🌏",
          "locked": true,
          "questions": []
        }
      ],
      "grammar": {
        "sections": [
          {
            "type": "intro",
            "content": "本章节介绍日语最基础的句型——用「は」和「です」进行自我介绍。掌握这些句型，你就能说出「我是×××」「我不是×××」等表达，迈出日语学习的第一步！"
          },
          {
            "type": "grammar-rule",
            "badge": "肯定句",
            "badgeColor": "#5B4FE9",
            "title": "〜は〜です",
            "reading": "〜 wa 〜 desu",
            "description": "表示「A 是 B」的基本句型。「は」是话题助词，读作「wa」（注意：字形是「は」但发音是「wa」）；「です」是礼貌体的判断助动词，相当于汉语的「是」。",
            "pattern": [
              { "label": "话题", "color": "#5B4FE9" },
              { "text": "は" },
              { "label": "说明", "color": "#0891B2" },
              { "text": "です" }
            ],
            "examples": [
              {
                "parts": [{"t":"私","k":"わたし"},{"t":"は"},{"t":"田中","k":"たなか"},{"t":"です。"}],
                "cn": "我是田中。"
              },
              {
                "parts": [{"t":"彼","k":"かれ"},{"t":"は"},{"t":"学生","k":"がくせい"},{"t":"です。"}],
                "cn": "他是学生。"
              },
              {
                "parts": [{"t":"これは"},{"t":"本","k":"ほん"},{"t":"です。"}],
                "cn": "这是书。"
              }
            ]
          },
          {
            "type": "tip",
            "icon": "💡",
            "title": "「は」的发音",
            "content": "「は」单独作助词使用时，发音是「wa（ワ）」而不是「ha（ハ）」。这是日语中的特殊读法，字形和读音不同，学习时需特别留意。"
          },
          {
            "type": "grammar-rule",
            "badge": "否定句",
            "badgeColor": "#EF4444",
            "title": "〜は〜ではありません",
            "reading": "〜 wa 〜 dewa arimasen",
            "description": "「です」的否定形式，表示「A 不是 B」。正式场合用「ではありません」，日常口语可简化为「じゃありません」甚至「じゃない」。",
            "pattern": [
              { "label": "话题", "color": "#5B4FE9" },
              { "text": "は" },
              { "label": "说明", "color": "#0891B2" },
              { "text": "ではありません" }
            ],
            "casual": "口语简化：〜じゃありません　／　〜じゃない",
            "examples": [
              {
                "parts": [{"t":"私","k":"わたし"},{"t":"は"},{"t":"先生","k":"せんせい"},{"t":"ではありません。"}],
                "cn": "我不是老师。"
              },
              {
                "parts": [{"t":"田中","k":"たなか"},{"t":"さんは"},{"t":"中国人","k":"ちゅうごくじん"},{"t":"ではありません。"}],
                "cn": "田中先生不是中国人。"
              },
              {
                "parts": [{"t":"山田","k":"やまだ"},{"t":"さんはアメリカ"},{"t":"人","k":"じん"},{"t":"じゃありません。"}],
                "cn": "山田先生不是美国人。",
                "note": "口语形式"
              }
            ]
          },
          {
            "type": "grammar-rule",
            "badge": "疑问句",
            "badgeColor": "#F59E0B",
            "title": "〜は〜ですか",
            "reading": "〜 wa 〜 desu ka",
            "description": "在「です」句末加上「か」，即可将陈述句变成疑问句。日语疑问句无需改变语序，只需在句尾加「か」即可。书面语句末通常不加「？」。",
            "pattern": [
              { "label": "话题", "color": "#5B4FE9" },
              { "text": "は" },
              { "label": "说明", "color": "#0891B2" },
              { "text": "ですか" }
            ],
            "examples": [
              {
                "parts": [{"t":"あなたは"},{"t":"学生","k":"がくせい"},{"t":"ですか？"}],
                "cn": "你是学生吗？"
              },
              {
                "parts": [{"t":"はい、"},{"t":"学生","k":"がくせい"},{"t":"です。"}],
                "cn": "是的，（我）是学生。",
                "note": "肯定回答"
              },
              {
                "parts": [{"t":"いいえ、"},{"t":"学生","k":"がくせい"},{"t":"ではありません。"}],
                "cn": "不，（我）不是学生。",
                "note": "否定回答"
              }
            ]
          },
          {
            "type": "vocabulary",
            "title": "本章核心单词",
            "words": [
              { "jp": "私",         "kana": "わたし",        "cn": "我",    "pos": "代词" },
              { "jp": "あなた",     "kana": "あなた",        "cn": "你",    "pos": "代词" },
              { "jp": "彼",         "kana": "かれ",          "cn": "他",    "pos": "代词" },
              { "jp": "彼女",       "kana": "かのじょ",      "cn": "她",    "pos": "代词" },
              { "jp": "学生",       "kana": "がくせい",      "cn": "学生",  "pos": "名词" },
              { "jp": "先生",       "kana": "せんせい",      "cn": "老师",  "pos": "名词" },
              { "jp": "医者",       "kana": "いしゃ",        "cn": "医生",  "pos": "名词" },
              { "jp": "日本人",     "kana": "にほんじん",    "cn": "日本人","pos": "名词" },
              { "jp": "中国人",     "kana": "ちゅうごくじん","cn": "中国人","pos": "名词" },
              { "jp": "アメリカ人", "kana": "アメリカじん",  "cn": "美国人","pos": "名词" },
              { "jp": "本",         "kana": "ほん",          "cn": "书",    "pos": "名词" },
              { "jp": "かばん",     "kana": "かばん",        "cn": "包",    "pos": "名词" }
            ]
          },
          {
            "type": "tip",
            "icon": "🎌",
            "title": "敬称「さん」",
            "content": "「さん」是日语中最常用的敬称，相当于中文的「先生／女士」，男女通用，加在姓名后面使用。直接称呼老师时，不在「先生」后加「さん」，直接说「先生」即可。"
          },
          {
            "type": "tip",
            "icon": "📝",
            "title": "日语语序：谓语在句末",
            "content": "日语是「主语—宾语—谓语（SOV）」语言，谓语动词始终放在句末。这与英语（SVO）和中文不同。例如：「私は（主）学生（宾）です（谓）。」学习时请牢记这一规律。"
          }
        ]
      }
    }
  ]
}
