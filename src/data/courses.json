              "prompt": "将句子翻译成中文",
              "sentence": "山田さんはアメリカ人ではありません。",
              "options": ["山田", "不是", "美国人", "学生", "老师"],
              "answers": ["山田", "不是", "美国人"],
              "translation": "山田不是美国人。",
              "hint": "「ではありません」是「です」的否定形式",
              "ruby": { "山田": "やまだ", "人": "じん" }
            },
            {
              "id": "q6",
              "type": "word-fill",
              "prompt": "选出正确的词语，完成句子",
              "parts": ["鈴木さん", "___", "医者です。"],
              "options": ["は", "が", "を", "の"],
              "answers": ["は"],
              "translation": "铃木是医生。",
              "hint": "「さん」是日语中的通用敬称",
              "ruby": { "鈴木": "すずき", "医者": "いしゃ" }
            },
            {
              "id": "q7",
              "type": "sentence-translate",
              "prompt": "将句子翻译成中文",
              "sentence": "あれはわたしのかばんです。",
