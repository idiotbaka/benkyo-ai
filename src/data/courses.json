          "icon": "📖",
          "questions": [
            {
              "id": "q1",
              "type": "word-fill",
              "prompt": "选出正确的词语，完成句子",
              "parts": ["私", "___", "田中です。"],
              "options": ["は", "が", "を", "に"],
              "answers": ["は"],
              "translation": "我是田中。",
              "hint": "「は」是话题助词，读作「wa」，标记主题",
              "ruby": { "私": "わたし", "田中": "たなか" }
            },
            {
              "id": "q2",
              "type": "sentence-translate",
              "prompt": "将句子翻译成中文",
              "sentence": "田中さんは学生です。",
              "options": ["田中", "是", "学生", "老师", "我"],
              "answers": ["田中", "是", "学生"],
              "translation": "田中是学生。",
              "hint": "「です」是礼貌体的判断助动词，相当于「是」",
              "ruby": { "田中": "たなか", "学生": "がくせい" }
            },
            {
              "id": "q3",
              "type": "word-fill",
              "prompt": "选出正确的词语，完成句子",
              "parts": ["私は先生", "___", "ありません。"],
              "options": ["では", "でも", "での", "でが"],
              "answers": ["では"],
              "translation": "我不是老师。",
              "hint": "否定句型：〜は〜ではありません",
              "ruby": { "私": "わたし", "先生": "せんせい" }
            },
            {
              "id": "q4",
              "type": "word-match",
              "prompt": "点击配对，消消看！",
